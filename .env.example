# Paper Live Smoke — credentials only. Copy to .env (gitignored) and fill in.
#
# .env is loaded by the Makefile (`include .env; export`); the SDK itself never
# reads a .env file. Use KEY=VALUE lines with no quotes and no `export` keyword.

LS_TRADING_ENV=paper
LS_PAPER_APPKEY=
LS_PAPER_SECRET=
LS_PAPER_ACCOUNT=

# Optional per-invocation overrides — pass on the command line, not required here:
#   make live-smoke LS_LIVE_SMOKE_SHCODE=005930
#   make live-smoke-chart LS_LIVE_SMOKE_T8412_DATE=20260612   # required for the chart target; NO default
# LS_LIVE_SMOKE_SHCODE=005930

# --- Real environment (opt-in) ---
# Do NOT use these for the paper smoke. The paper smoke refuses to run unless
# LS_TRADING_ENV=paper, but keeping real-money keys in the SAME .env that feeds
# paper runs is a hazard — prefer a separate shell profile or secret manager.
# LS_REAL_APPKEY=
# LS_REAL_SECRET=
# LS_REAL_ACCOUNT=

# --- WARNING: legacy fallback vars ---
# The bare names LS_APPKEY / LS_SECRET / LS_ACCOUNT are a legacy fallback that a
# PAPER run will pick up when LS_PAPER_* is unset. If real-money keys are exported
# as LS_APPKEY in your shell, a paper smoke could authenticate with them. Always
# use the LS_PAPER_* prefixed names and avoid bare LS_APPKEY in your environment.
