# Paper Live Smoke — credentials only. Copy to .env (gitignored) and fill in.
#
# .env is sourced by the Makefile through the shell; the SDK itself never reads a
# .env file. KEY=VALUE lines; surrounding quotes are optional (the shell strips
# them) and no `export` keyword is needed.

LS_TRADING_ENV=paper
LS_PAPER_APIKEY=
LS_PAPER_SECRET=
LS_PAPER_ACCOUNT=

# --- Per-account credential lanes ---
# Each LS paper account is bound to its OWN appkey — the account number is never
# sent on the wire, so the resolved account is whichever account the appkey's
# token authenticates as. Multi-account access is therefore one credential file
# per account, each a (LS_PAPER_APIKEY, LS_PAPER_SECRET, LS_PAPER_ACCOUNT) triple.
# The smoke harness sources the right lane file per TR (by instrument_domain):
#
#   .env / .env.domestic        domestic cash + overseas-stock   (account ...01)
#   .env.domestic_option        F/O (futures_options)            (account ...51)
#   .env.overseas               overseas-stock                   (account ...01)
#   .env.overseas_option        overseas-F/O (overseas_futures)  (account ...71)
#
# All four lane files use the LS_PAPER_APIKEY name and live at the repo root so
# the .gitignore `.env.*` rule keeps them untracked. The Makefile maps a smoke
# target to its lane via LS_SMOKE_LANE and sources `.env.<lane>` in the recipe.

# The appkey var name was renamed LS_PAPER_APPKEY -> LS_PAPER_APIKEY. The old
# name is still accepted as a back-compat alias (LS_PAPER_APIKEY wins if both set).

# Optional per-invocation overrides — pass on the command line, not required here:
#   make live-smoke LS_LIVE_SMOKE_SHCODE=005930
#   make live-smoke-chart LS_LIVE_SMOKE_T8412_DATE=20260612   # required for the chart target; NO default
# LS_LIVE_SMOKE_SHCODE=005930

# --- Real environment (opt-in) ---
# Do NOT use these for the paper smoke. The paper smoke refuses to run unless
# LS_TRADING_ENV=paper, but keeping real-money keys in the SAME .env that feeds
# paper runs is a hazard — prefer a separate shell profile or secret manager.
# LS_REAL_APPKEY=
# LS_REAL_SECRET=
# LS_REAL_ACCOUNT=

# --- WARNING: legacy fallback vars + real-money interlock ---
# The bare names LS_APPKEY / LS_SECRET / LS_ACCOUNT are a legacy fallback that a
# PAPER run will pick up ONLY when no LS_PAPER_* appkey is set. To prevent a paper
# smoke from silently authenticating with real-money keys, from_env now FAILS FAST
# when a paper appkey (LS_PAPER_APIKEY / LS_PAPER_APPKEY) and a real-money-capable
# name (LS_APPKEY / LS_REAL_APPKEY) are both present, and a paper run never resolves
# to LS_REAL_APPKEY. Always use the LS_PAPER_* prefixed names and avoid bare
# LS_APPKEY in your environment.
